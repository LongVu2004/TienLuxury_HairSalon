@{
    ViewData["Title"] = "Hair Salon Chatbot";
}

<div class="chat-container" style="width:400px;margin:auto;margin-top:40px;">
    <h2>💬 Chatbot Hair Salon</h2>

    <div id="chatBox"
         style="border:1px solid #ccc;height:400px;overflow-y:auto;padding:10px;">
    </div>

    <div style="margin-top:10px;">
        <input type="text" id="message" class="form-control" placeholder="Nhập tin nhắn..." />
        <button onclick="sendMessage()" class="btn btn-primary" style="margin-top:5px;">
            Gửi
        </button>
    </div>
</div>

<script>
    function sendMessage() {
        var userMessage = $("#message").val();
        if (userMessage.trim() === "") return;

        $("#chatBox").append("<p><b>Bạn:</b> " + userMessage + "</p>");

        $.ajax({
            url: "/Chat/SendMessage",
            type: "POST",
            data: { message: userMessage },
            success: function(res) {
                $("#chatBox").append("<p><b>Bot:</b> " + res.reply + "</p>");
                $("#chatBox").scrollTop($("#chatBox")[0].scrollHeight);
            }
        });

        $("#message").val("");
    }
</script>
