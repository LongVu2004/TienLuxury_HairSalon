@model SuccessfulViewModel

<link href="~/css/non-admin-style/order-successfull-style.css" rel="stylesheet">

@if (Model != null)
{
    <div class="success-container">
        <div class="success-header">
            <div class="success-header">
                <div class="success-icon">
                    <i class="fa-solid fa-check"></i>
                </div>
                <h1 class="success-title">Đặt hàng thành công!</h1>
                <p class="success-subtitle">Cảm ơn bạn đã đặt hàng tại cửa hàng chúng tôi</p>
            </div>
        </div>

        <div class="content-wrapper">
            <div class="order-info">
                <div class="info-box">
                    <h2 class="order-id">@Model.Invoice.ID</h2>
                    <p class="order-date">Ngày tạo: @Model.Invoice.CreatedDate</p>

                    <div class="info-row">
                        <span class="info-label">Khách hàng:</span>
                        <span class="info-value">@Model.Invoice.CustomerName</span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Số điện thoại:</span>
                        <span class="info-value">@Model.Invoice.PhoneNumber</span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Email:</span>
                        <span class="info-value">@Model.Invoice.Email</span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Địa chỉ:</span>
                        <span class="info-value">@Model.Invoice.Address</span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Trạng thái:</span>
                        <span class="info-value"><span class="status-badge">@Model.Invoice.Status</span></span>
                    </div>
                </div>
            </div>

            <div class="order-details">
                <div class="products-list">

                    @{
                        foreach (var i in Model.Items)
                        {
                            <div class="product-item">
                                <img src="@i.ImagePath" alt="@i.ProductName" class="product-image">
                                <span class="product-name">@i.ProductName</span>
                                <span class="product-quantity">x<span>@i.Quantity</span></span>
                                <span class="product-price">@i.ProductPrice.ToString("C0")</span>
                            </div>
                        }
                    }
                </div>

                <div class="order-summary">
                    <div class="summary-row">
                        <span class="total-label">Tạm tính:</span>
                        @{
                            // 1. Lấy tiền giảm giá (Xử lý null an toàn)
                            var discount = Model.Invoice.DiscountAmount.GetValueOrDefault();

                            // 2. Lấy tổng tiền khách phải trả (Tên đúng là Total)
                            var finalTotal = Model.Invoice.Total;

                            // 3. Cộng ngược lại để ra giá gốc
                            var subTotal = finalTotal + discount;
                        }
                        <span class="total-value" style="font-weight: normal;">@subTotal.ToString("C0")</span>
                    </div>

                    @if (discount > 0)
                    {
                        <div class="summary-row text-success">
                            <span class="total-label">
                                <i class="fas fa-ticket-alt"></i> Mã giảm giá (@(Model.Invoice.VoucherCode ?? "VOUCHER")):
                            </span>
                            <span class="total-value">-@discount.ToString("C0")</span>
                        </div>
                    }

                    <hr style="margin: 10px 0; border-color: #eee;">

                    <div class="summary-row">
                        <span class="total-label" style="font-size: 1.2rem; font-weight: bold;">Tổng tiền:</span>
                        <span class="total-value" style="font-size: 1.2rem; color: #d2b48c;">@finalTotal.ToString("C0")</span>
                    </div>

                    <p class="payment-method">Phương thức thanh toán: @Model.Invoice.PaymentMethod</p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="error-404">
        <script src="https://unpkg.com/@@dotlottie/player-component@2.7.12/dist/dotlottie-player.mjs"
            type="module"></script>
        <dotlottie-player src="https://lottie.host/20861518-cfd1-4f39-b48c-0cba3822036b/zcgpZFrg3Z.lottie"
            background="transparent" speed="1" style="width: 600px; height: 600px" loop autoplay></dotlottie-player>
    </div>
}
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Xóa thông tin đơn hàng nháp trong bộ nhớ trình duyệt
        localStorage.removeItem('draft_order');
        console.log("Đã dọn dẹp dữ liệu đơn hàng nháp.");
    });
</script>