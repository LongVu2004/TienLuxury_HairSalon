@{
    ViewData["Title"] = "Thanh toán chuyển khoản";
}

<link href="~/css/non-admin-style/payment-vietqr-style.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container">
    <div class="payment-container">
        <h3 style="color: #8e735b; font-weight: bold;">THANH TOÁN ĐƠN HÀNG</h3>
        <p class="text-muted">Vui lòng quét mã QR bên dưới để thanh toán</p>

        <img src="@ViewBag.QrUrl" alt="Mã QR Thanh Toán" class="qr-image" />

        <div class="bank-info">
            <p><strong>Ngân hàng:</strong> MB Bank (Quân Đội)</p>
            <p><strong>Chủ tài khoản:</strong> PHAM LONG VU</p>
            <p><strong>Số tài khoản:</strong> 0000956031794</p>
            <p><strong>Số tiền:</strong> <span style="color: #d9534f; font-weight: bold; font-size: 1.1rem;">@(((decimal)ViewBag.Amount).ToString("N0")) đ</span></p>

            <p>
                <strong>Nội dung:</strong>
                <span class="content-badge"
                      style="color: blue; font-weight: bold; background: #e7f3ff; padding: 4px 12px; border-radius: 4px; display: inline-block;">
                    @ViewBag.Content
                </span>
            </p>
        </div>

        <div class="alert alert-warning mt-3 text-start" style="font-size: 0.9rem;">
            <i class="fas fa-info-circle"></i> <b>Lưu ý:</b> Sau khi chuyển khoản thành công, vui lòng ấn nút bên dưới để hoàn tất.
        </div>

        <a href="@Url.Action("ConfirmPayment", "ShoppingCart", new { invoiceId = ViewBag.InvoiceId })" class="btn-finish"
           style="background-color: #d2b48c; color: white; padding: 12px 30px; border-radius: 25px; text-decoration: none; font-weight: bold; display: inline-block; margin-top: 10px;">
            <i class="fas fa-check-circle"></i> TÔI ĐÃ THANH TOÁN
        </a>

        <div class="mt-4">
            <a href="@Url.Action("CancelOrder", "ShoppingCart", new { invoiceId = ViewBag.InvoiceId })"
               class="text-danger text-decoration-none"
               style="font-size: 0.9rem; font-weight: 500;"
               onclick="confirmCancelQR(event, this.href)">
                <i class="fas fa-times-circle"></i> Hủy đơn & Quay lại mua sắm
            </a>
        </div>
    </div>
</div>

<script>
    function confirmCancelQR(event, url) {
        event.preventDefault();

        Swal.fire({
            title: 'Hủy giao dịch VietQR?',
            text: "Bạn có chắc muốn hủy giao dịch này?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Xác nhận',
            cancelButtonText: 'Quay lại'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = url;
            }
        })
    }
</script>