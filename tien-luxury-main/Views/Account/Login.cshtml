@using TienLuxury.ViewModels
@model LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập - Tien Luxury";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="icon" href="~/logo.png" type="image/x-icon">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <link rel="stylesheet" href="~/css/admin-style/login-style.css">

    <style>
        .register-link {
            color: #8e735b;
            text-decoration: none;
            font-size: 0.9rem;
        }

            .register-link:hover {
                color: #d4af37;
                text-decoration: underline;
            }
        /* Đảm bảo box login không bị co giãn lạ */
        .login-container {
            position: relative;
        }
    </style>
</head>

<body>
    <div class="container-fluid d-flex flex-column justify-content-center align-items-center">
        <div class="brand-content text-center mb-5">
            <div class="brand-text">
                <div class="tien-luxury-container justify-content-center">
                    <div class="tien">TIEN</div>
                    <div class="right-section">
                        <div class="luxury">Luxury</div>
                        <div class="slogan">Lấy lại phong độ</div>
                    </div>
                </div>
                <h2>Khách hàng thân thiết</h2>
            </div>
        </div>

        <div class="login-container">
            <h3 class="text-center mb-4">Đăng nhập</h3>

            <form method="post" asp-controller="Account" asp-action="Login">

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control"
                           placeholder="Nhập email">
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Mật khẩu</label>
                    <input asp-for="Password" type="password" class="form-control"
                           placeholder="Nhập mật khẩu">
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-center">
                    <button type="submit" class="btn btn-custom w-80">Đăng nhập</button>
                </div>

                @if (ViewBag.ErrorMessage != null)
                {
                    <p class="text-center mt-3 mb-1" style="color: indianred;">@ViewBag.ErrorMessage</p>
                }

                <div class="d-flex justify-content-between align-items-center mt-4 pt-2" style="border-top: 1px solid rgba(0,0,0,0.1);">
                    <a href="#" class="register-link" style="font-size: 0.85rem;">Quên mật khẩu?</a>
                    <a asp-action="Register" asp-controller="Account" class="register-link fw-bold">Đăng ký mới</a>
                </div>

            </form>
            <div class="text-center mt-3">
                <p class="text-muted">Hoặc đăng nhập bằng</p>

                <a href="@Url.Action("LoginByGoogle", "Account")" class="btn btn-outline-danger w-100 mb-2" style="border-radius: 8px;">
                    <i class="fab fa-google me-2"></i> Google
                </a>
                <a href="@Url.Action("LoginByFacebook", "Account")" class="btn btn-outline-primary w-100" style="border-radius: 8px;">
                    <i class="fab fa-facebook-f me-2"></i> Facebook
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>