@using TienLuxury.ViewModels
@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="~/css/non-admin-style/change-password-style.css" rel="stylesheet" />

<div class="container">
    <div class="password-container">
        <h3 class="text-center mb-4" style="color: #5a4a3f; font-weight: bold;">ĐỔI MẬT KHẨU</h3>

        <form asp-action="ChangePassword" method="post">

            @if (ViewBag.HasPassword == true)
            {
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">Mật khẩu cũ</label>
                    <input asp-for="OldPassword" type="password" class="form-control custom-input" placeholder="Nhập mật khẩu hiện tại" />
                    <span asp-validation-for="OldPassword" class="text-danger small"></span>
                </div>
            }
            else
            {
                <div class="alert alert-info border-0 shadow-sm mb-3">
                    <small><i class="fas fa-info-circle me-1"></i> Tài khoản của bạn liên kết với Google/Facebook và chưa có mật khẩu. Hãy tạo mật khẩu mới để có thể đăng nhập bằng Email.</small>
                </div>
            }

            <div class="mb-3">
                <label class="form-label fw-bold text-muted small">Mật khẩu mới</label>
                <input asp-for="NewPassword" type="password" class="form-control custom-input" placeholder="Nhập mật khẩu mới" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-muted small">Xác nhận mật khẩu mới</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control custom-input" placeholder="Nhập lại mật khẩu mới" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-submit">
                @(ViewBag.HasPassword == true ? "XÁC NHẬN THAY ĐỔI" : "TẠO MẬT KHẨU MỚI")
            </button>

            <a href="@Url.Action("Profile", "Account")" class="btn-back">
                <i class="fas fa-arrow-left me-1"></i> Quay lại Hồ sơ
            </a>
        </form>
    </div>
</div>