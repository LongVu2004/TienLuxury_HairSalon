@model TienLuxury.Areas.Admin.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Administrator page";
}

@functions {
    public string GetTimeAgo(DateTime date)
    {
        var span = DateTime.Now - date.ToLocalTime();

        if (span.TotalMinutes < 1) return "Vừa xong";
        if (span.TotalMinutes < 60) return $"{Math.Floor(span.TotalMinutes)} phút trước";
        if (span.TotalHours < 24) return $"{Math.Floor(span.TotalHours)} giờ trước";
        if (span.TotalDays < 7) return $"{Math.Floor(span.TotalDays)} ngày trước";

        return date.ToLocalTime().ToString("dd/MM/yyyy HH:mm");
    }
}


<link href="~/css/admin-style/dash-board-style.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script src="~/js/admin-script/admin-home-script.js"></script>

<nav class="navbar navbar-light">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <span class="navbar-brand">Dashboard</span>
        <div class="datetime-container">
            <span class="datetime-label">Hiện tại: <span id="datetime"></span></span>
        </div>
    </div>
</nav>

<div class="dashboard-container" id="dashboard">
    <div class="row mb-4">
        <div class="col-12">
            <div class="dashboard-card">
                <h2 class="mb-4" style="color: var(--accent-color);">Welcome to Tien Luxury Website Management</h2>
                <p>Đây là trang quản trị nơi bạn có thể quản lý nội dung trang web và theo dõi số liệu hiệu suất trong
                    tầm tay.</p>
            </div>
        </div>
    </div>

    <div class="row">

        <div class="col-md-3 col-sm-6">
            <div class="stats-card">
                <div class="stats-icon">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
                <div class="stats-info">
                    <h3>@Model.ReservationsToDay</h3>
                    <p>Reservations Today</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="stats-card">
                <div class="stats-icon">
                    <i class="fa-solid fa-cart-shopping"></i>
                </div>
                <div class="stats-info">
                    <h3>@Model.OrdersToday</h3>
                    <p>Pending orders</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="stats-card">
                <div class="stats-icon">
                    <i class="fa-solid fa-gears"></i>
                </div>
                <div class="stats-info">
                    <h3>@Model.NumberOfServices</h3>
                    <p>Services</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="stats-card">
                <div class="stats-icon">
                    <i class="fa-solid fa-box"></i>
                </div>
                <div class="stats-info">
                    <h3>@Model.NumberOfProducts</h3>
                    <p>Products</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="dashboard-card">
                <h5 class="card-title mb-3">Hoạt động gần đây</h5>
                <div class="recent-activities">
                    <div class="recent-item d-flex align-items-center mb-3">
                        <div class="me-3">
                            <i class="fa-regular fa-calendar-check fa-2x" style="color: var(--accent-color);"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-bold">Lịch hẹn sắp tới</h6>
                            @if (Model.NearestBooking != null)
                            {
                                <div class="text-muted small">
                                    Khách: <strong>@Model.NearestBooking.FullName</strong> <br>
                                    Thời gian: <span style="color: #d2b48c; font-weight: bold;">
                                        @Model.NearestBooking.ReservationDate.ToLocalTime().ToString("HH:mm - dd/MM/yyyy")
                                    </span>
                                </div>
                            }
                            else
                            {
                                <small class="text-muted">Không có lịch hẹn nào sắp tới.</small>
                            }
                        </div>
                    </div>

                    <div class="recent-item d-flex align-items-center mb-3">
                        <div class="me-3">
                            <i class="fa-solid fa-cart-shopping fa-2x" style="color: var(--hover-color);"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-bold">Đơn hàng mới nhất</h6>
                            @if (Model.LatestOrder != null)
                            {
                                <div class="text-muted small">
                                    Khách: <strong>@Model.LatestOrder.CustomerName</strong> -
                                    <span class="text-success fw-bold">@Model.LatestOrder.Total.ToString("N0") đ - @Model.LatestOrder.Status</span>
                                    <br>
                                    <i class="far fa-clock me-1"></i> @GetTimeAgo(Model.LatestOrder.CreatedDate)
                                </div>
                            }
                            else
                            {
                                <small class="text-muted">Chưa có đơn hàng nào.</small>
                            }
                        </div>
                    </div>

                    <div class="recent-item d-flex align-items-center">
                        <div class="me-3">
                            <i class="fa-solid fa-inbox fa-2x" style="color: var(--hover-color);"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-bold">Đánh giá mới</h6>
                            @if (Model.LatestMessage != null)
                            {
                                <div class="text-muted small">
                                    Từ: <strong>@Model.LatestMessage.CustomerName</strong> <br>

                                    <span class="text-truncate d-inline-block" style="max-width: 200px;">
                                        "@Model.LatestMessage.Content"
                                    </span>
                                    <br>
                                    <i class="far fa-clock me-1"></i> @GetTimeAgo(Model.LatestMessage.CreatedAt)
                                </div>
                            }
                            else
                            {
                                <small class="text-muted">Hộp thư trống.</small>
                            }
                        </div>
                    </div>
                </div>
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card shadow-sm border-0" style="border-radius: 16px;">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <h4 class="card-title mb-0" style="color: #d2b48c; font-weight: bold;">Biểu đồ doanh thu</h4>

                                    <div class="btn-group" role="group">
                                        <button type="button" class="btn btn-outline-gold active" onclick="loadChart('day', this)">Ngày</button>
                                        <button type="button" class="btn btn-outline-gold" onclick="loadChart('month', this)">Tháng</button>
                                        <button type="button" class="btn btn-outline-gold" onclick="loadChart('year', this)">Năm</button>
                                    </div>
                                </div>

                                <div id="revenueChart" style="min-height: 350px;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 mb-4">
            <div class="dashboard-card">
                <h5 class="card-title mb-3">Quick Access</h5>
                <div class="list-group">
                    <a href="@Url.Action("AddProduct", "ProductsManagement")"
                        class="list-group-item list-group-item-action d-flex align-items-center">
                        <i class="fa-solid fa-plus me-3" style="color: var(--primary-color);"></i>
                        <span>New Product</span>
                    </a>

                    <a id="addServiceBtn" href=""
                        class="list-group-item list-group-item-action d-flex align-items-center">
                        <i class="fa-solid fa-plus me-3" style="color: var(--secondary-color);"></i>
                        <span>New Service</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal-overlay" id="serviceFormContainer" style="display: none;">
    <div class="modal-content">
        <div class="modal-body">
        </div>
    </div>
</div>

