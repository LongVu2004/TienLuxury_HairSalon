@model TienLuxury.Areas.Admin.ViewModels.VoucherAddEditViewModel
@{
    ViewData["Title"] = "Cập nhật Voucher";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<link href="~/css/admin-style/voucher-management-style.css" rel="stylesheet" />

<div class="voucher-container">
    <h2 class="voucher-title mb-4">Cập nhật Voucher: @Model.Voucher.Code</h2>

    <div class="voucher-table-card" style="max-width: 800px; margin: 0 auto;">
        <form asp-action="UpdateVoucher" method="post">
            <input type="hidden" asp-for="Voucher.Id" />
            <input type="hidden" asp-for="Voucher.UsedCount" />
            @for (int i = 0; i < Model.Voucher.UsedByUserIds.Count; i++)
            {
                <input type="hidden" name="Voucher.UsedByUserIds[@i]" value="@Model.Voucher.UsedByUserIds[i]" />
            }

            <div class="row">
                <div class="col-md-6 form-group">
                    <label>Mã Voucher</label>
                    <input asp-for="Voucher.Code" class="form-input" readonly style="background: #e9ecef;" />
                </div>
                <div class="col-md-6 form-group">
                    <label>Tổng số lượng</label>
                    <input asp-for="Voucher.Quantity" type="number" class="form-input" required min="1" />
                    <small class="text-info">Đã dùng: @Model.Voucher.UsedCount vé</small>
                </div>
            </div>

            <div class="form-group">
                <label>Mô tả</label>
                <input asp-for="Voucher.Description" class="form-input" />
            </div>

            <hr class="my-4" />

            <div class="row">
                <div class="col-md-4 form-group">
                    <label>Loại giảm giá</label>
                    <select asp-for="Voucher.DiscountType" class="form-input" id="discountType" onchange="toggleMaxDiscount()">
                        <option value="PERCENT">Phần trăm (%)</option>
                        <option value="FIXED">Tiền mặt (VNĐ)</option>
                    </select>
                </div>
                <div class="col-md-4 form-group">
                    <label>Giá trị giảm</label>
                    <input asp-for="Voucher.Value" type="number" class="form-input" required min="0" />
                </div>
                <div class="col-md-4 form-group" id="maxDiscountGroup">
                    <label>Giảm tối đa (VNĐ)</label>
                    <input asp-for="Voucher.MaxDiscountAmount" type="number" class="form-input" min="0" />
                </div>
            </div>

            <div class="form-group">
                <label>Đơn tối thiểu</label>
                <input asp-for="Voucher.MinOrderAmount" type="number" class="form-input" min="0" />
            </div>

            <div class="row">
                <div class="col-md-6 form-group">
                    <label>Ngày bắt đầu</label>
                    <input asp-for="Voucher.StartDate" class="form-input" required />
                </div>
                <div class="col-md-6 form-group">
                    <label>Ngày kết thúc</label>
                    <input asp-for="Voucher.EndDate" class="form-input" required />
                </div>
            </div>

            <div class="form-group">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" asp-for="Voucher.IsActive">
                    <label class="form-check-label">Đang kích hoạt</label>
                </div>
            </div>

            <div class="text-end mt-4">
                <a href="@Url.Action("Index")" class="btn btn-secondary me-2">Hủy bỏ</a>
                <button type="submit" class="btn btn-primary" style="background: var(--primary-color); border: none;">Cập nhật</button>
            </div>
        </form>
    </div>
</div>

<script>
    function toggleMaxDiscount() {
        var type = document.getElementById("discountType").value;
        var maxGroup = document.getElementById("maxDiscountGroup");
        if (type === "PERCENT") {
            maxGroup.style.display = "block";
        } else {
            maxGroup.style.display = "none";
        }
    }
    window.onload = toggleMaxDiscount;
</script>