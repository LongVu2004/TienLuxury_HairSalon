@model IEnumerable<TienLuxury.Models.AppUser>

@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link href="~/css/admin-style/Invoice-management-style.css" rel="stylesheet" />
<link href="~/css/admin-style/dash-board-style.css" rel="stylesheet" />

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<nav class="navbar navbar-light">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <span class="navbar-brand">Users Management</span>
        <div class="datetime-container">
            <span class="datetime-label">Hiện tại: <span id="datetime"></span></span>
        </div>
    </div>
</nav>

<div class="orders-container">
    <div class="table-wrapper">

        <div class="table-header">
            <h2>Danh Sách Người Dùng</h2>

            <div class="filter-section" style="margin-bottom: 15px;">
                <form asp-action="Index" method="get" class="d-flex align-items-center">
                    <label style="margin-right: 10px; color: var(--text-color); white-space: nowrap;">Tìm kiếm:</label>

                    <input type="text" name="searchString" value="@ViewBag.CurrentFilter"
                           placeholder="Tên, Email hoặc SĐT..."
                           style="padding: 0.5rem; border-radius: 10px; border: 1px solid var(--text-color);
                                  background: var(--card-color); color: var(--text-color); outline: none; margin-right: 10px;">

                    <button type="submit" class="btn" style="background-color: var(--primary-color); color: white; border-radius: 10px;">
                        <i class="fas fa-search"></i>
                    </button>

                    @if (!string.IsNullOrEmpty(ViewBag.CurrentFilter as string))
                    {
                        <a asp-action="Index" class="btn ms-2" style="background-color: #6c757d; color: white; border-radius: 10px;">
                            <i class="fas fa-undo"></i>
                        </a>
                    }
                </form>
            </div>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Họ và tên</th>
                        <th class="customer-name-row">Email</th>
                        <th>SĐT</th>
                        <th>Vai trò</th>
                        <th>Ngày tham gia</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="order-row">
                                <td class="fw-bold">@item.FullName</td>
                                <td class="customer-name-row">@item.Email</td>
                                <td>@(string.IsNullOrEmpty(item.PhoneNumber) ? "---" : item.PhoneNumber)</td>

                                <td>
                                    <form asp-action="UpdateRole" method="post" style="margin: 0;">
                                        <input type="hidden" name="id" value="@item.Id" />

                                        <select name="newRole" onchange="this.form.submit()"
                                                class="form-select form-select-sm fw-bold shadow-none"
                                                style="width: 145px; cursor: pointer;
                                                       border: 2px solid @(item.Role == "Admin" ? "#d9534f" : "#5cb85c");
                                                       color: @(item.Role == "Admin" ? "#d9534f" : "#5cb85c");
                                                       background-color: transparent;
                                                       border-radius: 15px; text-align: center;">

                                            @if (item.Role == "Admin")
                                            {
                                                <option value="Admin" selected style="color: #d9534f; font-weight: bold;">Quản trị viên</option>
                                                <option value="Customer" style="color: #5cb85c;">Khách hàng</option>
                                            }
                                            else
                                            {
                                                <option value="Admin" style="color: #d9534f;">Quản trị viên</option>
                                                <option value="Customer" selected style="color: #5cb85c; font-weight: bold;">Khách hàng</option>
                                            }
                                        </select>
                                    </form>
                                </td>

                                <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>

                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm" style="background: var(--secondary-color); color: white; border-radius: 8px; margin-right: 5px;">
                                        <i class="fas fa-info-circle"></i>
                                    </a>

                                    @if (item.Role != "Admin")
                                    {
                                        <button type="button" class="btn btn-sm" style="background: #d9534f; color: white; border-radius: 8px;"
                                                onclick="confirmDelete('@item.Id', '@item.FullName')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center" style="padding: 2rem; color: var(--text-color);">
                                <i class="fas fa-search mb-2" style="font-size: 2rem; opacity: 0.5;"></i><br>
                                Không tìm thấy khách hàng nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    <input type="hidden" name="id" id="deleteId" />
</form>

<script>
    

    // 2. Xử lý xóa
    function confirmDelete(id, name) {
        Swal.fire({
            title: 'Xóa tài khoản?',
            text: `Bạn có chắc chắn muốn xóa khách hàng: ${name}?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d9534f',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Xóa ngay',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        })
    }
</script>