<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HairSalonWeb Admin</title>

    <link rel="icon" href="~/logo.png" type="image/x-icon">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
    <link href="~/css/admin-style/admin-style.css" rel="stylesheet" />
</head>

<body>
    <div class="sidebar" id="sidebar">
        <div class="logo-container">
            <i class="fas fa-laptop-code" style="color: var(--accent-color);"></i>
            <div class="logo">AdminPanel</div>
        </div>
        <button class="toggle-btn" id="toggle-btn"><i class="fas fa-chevron-right"></i></button>
        <div class="sidebar-menu">
            <a href="@Url.Action("Index", "Home")">
                <i class="fa-solid fa-gauge"></i><span>Dashboard</span>
            </a>
            
            <a href="@Url.Action("Index", "VouchersManagement")">
                <i class="fa-solid fa-ticket"></i><span>Manage Vouchers</span>
            </a>

            <a href="@Url.Action("ServicesManagement", "Home")">
                <i class="fa-solid fa-cogs"></i><span>Manage Services</span>
            </a>

            <a href="@Url.Action("ProductsManagement", "Home")">
                <i class="fa-solid fa-box"></i><span>Manage Products</span>
            </a>

            <a href="@Url.Action("Index", "CategoriesManagement")">
                <i class="fa-solid fa-list"></i><span>Manage Categories</span>
            </a>

            <a href="@Url.Action("OrdersManagement", "Home")">
                <i class="fa-solid fa-cart-shopping"></i><span>Manage Orders</span>
            </a>

            <a href="@Url.Action("ReservationsManagement", "Home")">
                <i class="fa-solid fa-calendar-check"></i><span>Manage Appointments</span>
            </a>

            <a href="@Url.Action("EmployeesManagement", "Home")">
                <i class="fa-solid fa-users"></i><span>Manage Employees</span>
            </a>

            <a href="@Url.Action("Index", "AccountsManagement")">
                <i class="fa-solid fa-address-book"></i><span>Manage Accounts</span>
            </a>

            <a href="@Url.Action("Index", "ReviewsManagement")">
                <i class="fa-solid fa-star-half-stroke"></i><span>Manage Reviews</span>
            </a>

            <a href="@Url.Action("MessagesManagement", "Home")">
                <i class="fa-regular fa-comment-dots"></i><span>Manage Messages</span></a>
            <a href="#settings" class="settings-btn">
                <i class="fa-solid fa-gear"></i><span>Settings</span>
            </a>
            <div class="submenu" id="settings-submenu">
                @* <a href="#profile"><i class="fa-solid fa-user"></i><span>Profile</span></a> *@
                <a href="" id="changePasswordBtn"><i class="fa-solid fa-key"></i><span>Change Password</span></a>
                <a href="@Url.Action("Logout", "Home", new {area = "Admin"})"><i
                        class="fa-solid fa-right-from-bracket"></i><span>Logout</span></a>
            </div>
        </div>
    </div>

    <div class="content" id="content">
        @RenderBody()
    </div>

    <div class="custome-form-container" id="changePasswordFormContainer"
        style="position: fixed; z-index: 1050; top: 0; left: 0; width: 100%; height: 100%; display: none; background-color: rgba(0,0,0,0.5); overflow-y: auto;">
    </div>

    @await RenderSectionAsync("Scripts", required: false)

    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin-script/admin-index-script.js"></script>
    <script src="~/js/admin-script/show-change-password-script.js"></script>
    <script src="~/js/admin-script/service-management-script.js"></script>
    <script src="~/js/admin-script/product-management-script.js"></script>
    <script src="~/js/admin-script/reservation-management-script.js"></script>
    <script src="~/js/admin-script/employee-management-script.js"></script>
    <script src="~/js/admin-script/check-validation-product.js"></script>

    <link href="https://cdn.jsdelivr.net/npm/summernote@0.9.0/dist/summernote-lite.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.9.0/dist/summernote-lite.min.js"></script>

    <script>
        $('#summernote').summernote({
            placeholder: 'Mô Tả sản phẩm',
            tabsize: 4,
            toolbar: [
                ['style', ['style']],
                ['font', ['bold', 'underline', 'clear']],
                ['color', ['color']],
                ['para', ['ul', 'ol', 'paragraph']],
                ['table', ['table']],
                ['insert', ['link', 'picture', 'video']],
                ['view', ['fullscreen', 'codeview', 'help']]

            ]
        });

        // Cấu hình Toast (Thông báo góc)
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end', // Hiện ở góc trên bên phải
            showConfirmButton: false,
            timer: 3000, // Tự mất sau 3 giây
            timerProgressBar: true,
            didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer)
                toast.addEventListener('mouseleave', Swal.resumeTimer)
            }
        });

        // Kiểm tra nếu có SuccessMessage từ Controller
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
                        Toast.fire({
                            icon: 'success',
                            title: '@TempData["SuccessMessage"]'
                        });
            </text>
        }

        // Kiểm tra nếu có ErrorMessage từ Controller
        @if (TempData["ErrorMessage"] != null)
        {
            <text>
                        Toast.fire({
                            icon: 'error',
                            title: '@TempData["ErrorMessage"]'
                        });
            </text>
        }
    </script>

</body>

</html>